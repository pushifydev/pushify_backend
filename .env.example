# ─── Server ───
NODE_ENV=development
PORT=4000

# ─── Database (PostgreSQL) ───
DATABASE_URL=postgresql://user:password@localhost:5432/pushify

# ─── Redis (optional — required for job queues) ───
# REDIS_URL=redis://localhost:6379

# ─── JWT Authentication ───
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ─── CORS ───
CORS_ORIGIN=http://localhost:3000

# ─── Frontend URL (used in emails, notifications) ───
FRONTEND_URL=http://localhost:3000

# ─── GitHub OAuth (optional — for GitHub repo integration) ───
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# ─── Email / SMTP (optional — for notifications) ───
# GMAIL_USER=noreply@example.com
# GMAIL_APP_PASSWORD=your-app-password
# GMAIL_FROM_NAME=Pushify

# ─── Preview Deployments (optional) ───
# PREVIEW_BASE_URL=preview.example.com

# ─── AI Assistant (optional — requires Anthropic API key) ───
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Encryption (required — used for encrypting SSH keys) ───
ENCRYPTION_KEY=generate-a-64-char-hex-string-here-use-openssl-rand-hex-32

# ─── Hetzner Cloud (optional — for server provisioning) ───
# HETZNER_API_TOKEN=your-hetzner-api-token

# ─── Rate Limiting ───
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_API_MAX=100
